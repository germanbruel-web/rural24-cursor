# ============================================================
# .env.db.example → copiá este archivo como .env.db.local
# NUNCA commitear .env.db.local (tiene credenciales reales)
# ============================================================

# URL de conexión a Supabase DEV y PROD.
# Soporta formato directo y formato pooler (IPv4 compatible):
#
#   Directo: postgresql://postgres:[PASS]@db.[REF].supabase.co:5432/postgres
#   Pooler:  postgresql://postgres.[REF]:[PASS]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#
# Recomendado: pooler con puerto 6543 (IPv4 compatible, sin add-on de IP dedicada)
# Los scripts convierten automáticamente 6543 → 5432 (session mode) para DDL.
# Fuente: Supabase Dashboard → Settings → Database → Connection string → URI

DEV_DB_URL=postgresql://postgres.[DEV-REF]:[PASSWORD]@aws-0-us-west-2.pooler.supabase.com:6543/postgres
PROD_DB_URL=postgresql://postgres.[PROD-REF]:[PASSWORD]@aws-0-us-west-2.pooler.supabase.com:6543/postgres
