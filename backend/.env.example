# Server Configuration
PORT=3001

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Entorno Cloudinary: 'dev' o 'prod'. Setear explícitamente en Render.
# NO usar NODE_ENV — Render siempre deploya con NODE_ENV=production.
CLOUDINARY_ENV=dev

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Environment
NODE_ENV=development

# Ads moderation (set to 'true' to auto-approve ads in dev)
AUTO_APPROVE_ADS=true

# Cron jobs security
CRON_SECRET=your_cron_secret_here

# Email — Zoho Mail SMTP (Sprint 3D.6)
# Crear cuenta en zoho.com/mail con info@rural24.com.ar
# Cloudflare verifica SPF/DKIM para evitar spam
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=info@rural24.com.ar
SMTP_PASS=your_zoho_password_here

# MercadoPago (Sprint 3D — checkout de Destacados)
# Usar TEST_xxx para sandbox, APP_USR-xxx para producción
MERCADOPAGO_ACCESS_TOKEN=TEST_your_access_token_here
# URL pública del backend (para notification_url del webhook MP)
BACKEND_PUBLIC_URL=http://localhost:3001
